{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",

    "target": "ES2022",

    "module": "NodeNext",
    "moduleResolution": "NodeNext",

    "types": ["node"],

    "sourceMap": true,

    "strict": true,

    "esModuleInterop": true,

    "isolatedModules": true,
    "skipLibCheck": true,

    "resolveJsonModule": true
  },
  "include": ["src"]
}